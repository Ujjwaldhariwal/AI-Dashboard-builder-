# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_EMAIL_DOMAIN=company.com

# Supabase (keep proxy URL if your setup uses a worker)
NEXT_PUBLIC_SUPABASE_URL=https://supabase-proxy.example.workers.dev
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# AI providers
GEMINI_API_KEY=your-gemini-key
OPENAI_API_KEY=your-openai-key

# Bosch proxy (server-only)
BOSCH_USERID=your-bosch-userid
BOSCH_PASSWORD=your-bosch-password


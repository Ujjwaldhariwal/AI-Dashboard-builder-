# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_EMAIL_DOMAIN=company.com

# Enables the authenticated, explicitly selected (?demo=1) prepared reference workspace on hosted deployments.
# This does not bypass authentication or enable write APIs.
NEXT_PUBLIC_DASHBOARDOS_DEMO_ENABLED=false

# Production hostname policy
# Comma-separated platform/admin hostnames allowed to serve DashboardOS system routes.
# Include the production app host and any Vercel preview hostnames you intentionally trust.
DASHBOARDOS_PLATFORM_HOSTNAMES=dashboardos.company.com

# Optional comma-separated root domains for tenant subdomains.
# When set, {tenantSlug}.clients.company.com resolves to the matching active tenant slug.
DASHBOARDOS_TENANT_ROOT_DOMAINS=clients.company.com

# Optional distributed runtime cache/rate limit backend.
# If unset, runtime query caching and rate limiting fall back to per-instance memory.
UPSTASH_REDIS_REST_URL=https://example.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://fmhwxggejoerbpawejro.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Background worker
# Required by POST /api/admin/jobs/worker. Send as Authorization: Bearer <secret>
# or x-dashboardos-worker-secret.
# Also required by POST /api/admin/jobs/scheduler for recurring job enqueue.
DASHBOARDOS_WORKER_SECRET=replace-with-a-long-random-secret

# Optional native alert email delivery through Resend.
# If unset, email alert channels may still use config.webhookUrl as an email-gateway fallback.
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL="DashboardOS Alerts <alerts@company.com>"
# DASHBOARDOS_RESEND_API_KEY=your-resend-api-key
# DASHBOARDOS_EMAIL_FROM="DashboardOS Alerts <alerts@company.com>"

# Optional alert delivery policy defaults.
# Channel config can override these with suppressionMinutes and escalationAfterMinutes.
DASHBOARDOS_ALERT_SUPPRESSION_MINUTES=60
DASHBOARDOS_ALERT_ESCALATION_MINUTES=240

# Optional legacy UI fallback for old local builder/viewer routes.
# Keep unset/false for production demos; set both values to true only for maintenance.
DASHBOARDOS_ENABLE_LEGACY_ROUTES=false
NEXT_PUBLIC_DASHBOARDOS_ENABLE_LEGACY_ROUTES=false

# Data-source vault and schema intelligence
DATA_SOURCE_ENCRYPTION_KEY=replace-with-a-32-byte-base64-key
# Fallback allowlist for credentials created before per-source schema selection existed.
# New sources persist their own schema allowlist and default to public.
DATA_SOURCE_SCHEMAS=public

# AI providers
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-key
GEMINI_API_KEY=your-gemini-key
OPENAI_API_KEY=your-openai-key

# Shared governed AI workflow routing.
# Providers: google, openai, openai_compatible. Defaults to google.
AI_PROVIDER=google
# AI_MODEL=gemini-2.5-flash

# Optional per-workflow provider/model overrides.
# AI_SEMANTIC_PROVIDER=google
# AI_SEMANTIC_MODEL=gemini-2.5-flash
# AI_DASHBOARD_PROVIDER=google
# AI_DASHBOARD_MODEL=gemini-2.5-flash
# AI_REPORT_PROVIDER=google
# AI_REPORT_MODEL=gemini-2.5-flash
# AI_CHART_PROVIDER=google
# AI_CHART_MODEL=gemini-2.5-flash
# AI_TRANSFORM_PROVIDER=google
# AI_TRANSFORM_MODEL=gemini-2.5-flash

# OpenAI-compatible local/private inference, such as Ollama or vLLM.
# AI_PROVIDER=openai_compatible
# AI_COMPATIBLE_PROVIDER_NAME=dashboardos-local
# AI_COMPATIBLE_BASE_URL=http://localhost:11434/v1
# AI_COMPATIBLE_MODEL=your-local-model
# AI_COMPATIBLE_API_KEY=
# AI_COMPATIBLE_STRUCTURED_OUTPUTS=true

# Bosch proxy (server-only)
BOSCH_USERID=your-bosch-userid
BOSCH_PASSWORD=your-bosch-password
BOSCH_BASE_URL=https://kadashboard.kaamismartmeters.com/BOSCH/API

# Optional: default target (used when x-bosch-env header is not provided)
# BOSCH_DEFAULT_ENV=KASHI

# Optional per-target credentials/base URLs
# BOSCH_USERID_KASHI=...
# BOSCH_PASSWORD_KASHI=...
# BOSCH_BASE_URL_KASHI=https://...
# BOSCH_USERID_PRAYAGRAJ=...
# BOSCH_PASSWORD_PRAYAGRAJ=...
# BOSCH_BASE_URL_PRAYAGRAJ=https://...
# BOSCH_USERID_AGRA=...
# BOSCH_PASSWORD_AGRA=...
# BOSCH_BASE_URL_AGRA=https://...
